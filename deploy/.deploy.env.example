# Copy this file to deploy/.deploy.env and fill in the values, then run
# deploy/deploy.sh. The .deploy.env file is gitignored — your SSH key path
# and EC2 hostname never reach the repo.
#
# All three variables are REQUIRED. The script aborts if any is missing.

# Public DNS of your EC2 instance, from the EC2 Console -> Instance summary.
# Example: ec2-13-50-1-23.eu-north-1.compute.amazonaws.com
# Note: AWS reassigns this DNS every time you stop+start the instance unless
# you allocate an Elastic IP. Re-edit this file after each restart, OR allocate
# an Elastic IP (free while attached to a running instance).
EC2_HOST=ec2-x-x-x-x.eu-north-1.compute.amazonaws.com

# Absolute or ~-prefixed path to the SSH private key (.pem) you downloaded
# when you created the EC2 key pair. Must be chmod 600.
SSH_KEY=~/.ssh/finnish-demo.pem

# SSH user. Defaults differ per AMI:
#   ec2-user  Amazon Linux 2023  (what TASK_09 walks you through)
#   ubuntu    Ubuntu AMIs
#   admin     Debian AMIs
# Stick to ec2-user unless you intentionally launched a non-AL2023 instance.
SSH_USER=ec2-user