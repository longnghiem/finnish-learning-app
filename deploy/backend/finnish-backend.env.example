# /etc/finnish-backend.env — runtime environment for finnish-backend.service.
#
# COPY THIS FILE to /etc/finnish-backend.env (the installer does this on first run)
# and fill in every value marked CHANGE_ME before starting the service.
#
# File permissions matter: this file contains the Postgres password and the JWT
# signing secret. The installer sets `chmod 600` and `chown root:finnish` so
# only root and the backend process can read it.
#
# After editing, restart the service to pick up changes:
#     sudo systemctl restart finnish-backend
#     journalctl -u finnish-backend -f

# ── Spring datasource ────────────────────────────────────────────────────────
# The 'finnish' role and 'finnish_learning_app' database were created by
# provision-ec2.sh. The password is NOT set by the script — you must run:
#     sudo -u postgres psql -c "ALTER USER finnish WITH PASSWORD '<paste-here>';"
# and then paste the same password into SPRING_DATASOURCE_PASSWORD below.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/finnish_learning_app
SPRING_DATASOURCE_USERNAME=finnish
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# ── Image storage ────────────────────────────────────────────────────────────
# Absolute path. Directory created (chown finnish:finnish, chmod 750) by
# provision-ec2.sh. LocalImageStorageService writes card image uploads here.
IMAGE_STORAGE_LOCATION=/var/lib/finnish/uploads

# ── JWT ──────────────────────────────────────────────────────────────────────
# JWT_SECRET signs every issued token. Anyone who knows it can mint admin
# tokens — keep it secret, keep it long. Generate a fresh one with:
#     openssl rand -base64 32
# Paste the output below. Do NOT reuse the dev secret from backend/.env.
JWT_SECRET=CHANGE_ME

# Token lifetime in milliseconds. 86_400_000 = 24 hours. Adjust if you want
# the demo session to expire sooner / later.
JWT_EXPIRATION_MS=86400000

# ── Kafka ────────────────────────────────────────────────────────────────────
# Local KRaft broker on loopback, installed by deploy/kafka/install-kafka.sh.
# Loopback-only — the broker is never reachable from outside the EC2 host.
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092

# ── CORS ─────────────────────────────────────────────────────────────────────
# Empty = same-origin only. nginx (TASK_07) serves the frontend AND proxies
# /api/* to this backend from the same hostname, so the browser never makes a
# cross-origin request. Leaving this empty means no Access-Control-* headers
# are emitted.
#
# Set to a comma-separated list of origins ONLY if you ever host the frontend
# on a different domain than the backend (e.g. you move dist/ to S3/CloudFront).
# Example:  APP_CORS_ALLOWED_ORIGINS=https://demo.example.com,http://localhost:5173
APP_CORS_ALLOWED_ORIGINS=